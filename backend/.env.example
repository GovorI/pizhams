# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=pizhams
DATABASE_PASSWORD=pizhams_password
DATABASE_NAME=pizhams

# App
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
APP_URL=http://localhost:3000

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=7d

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@pizhams.local

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=10

# Cloudflare R2 (Optional - для локальной разработки можно не указывать)
# Инструкции по настройке: https://developers.cloudflare.com/r2/api/s3/
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_BUCKET=pizhams
# Публичный URL для доступа к файлам (если настроен R2 Public Access)
# R2_PUBLIC_URL=https://pub-xxxx.r2.dev
